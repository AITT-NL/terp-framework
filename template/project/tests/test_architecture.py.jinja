"""The architecture gate — the same rules CI enforces, runnable locally.

A green run means the app is secure-by-default compliant. The example module ships its
first migration, so a fresh checkout passes clean.
"""

from __future__ import annotations

import importlib
import pathlib
import tomllib

from terp.arch import assert_app_clean
from terp.migrations import assert_migrations_match_models, upgrade

_APP_ROOT = pathlib.Path(__file__).resolve().parents[1] / "app"


def test_architecture() -> None:
    assert_app_clean("app", budget_path="escape-hatch-budget.json")


def test_generic_appsec_baseline_is_wired() -> None:
    # The Terp rules cover Terp-specific architecture; generic AppSec (command
    # injection, unsafe deserialization, weak hashes, ...) is delegated to ruff's
    # bandit-derived `S` baseline (platform ADR 0085), which CI runs as a blocking
    # step. This test keeps that delegation from being weakened silently: dropping
    # the select, widening the excusals, excluding app code, or removing the CI
    # step all require editing this test too -- a visible, reviewed decision.
    # Per-line opt-outs stay available as a `noqa` comment naming the S rule,
    # with a reason.
    project_root = pathlib.Path(__file__).resolve().parents[1]
    config = tomllib.loads((project_root / "pyproject.toml").read_text(encoding="utf-8"))
    ruff = config.get("tool", {}).get("ruff", {})
    lint = ruff.get("lint", {})
    assert "S" in lint.get("select", []), (
        "pyproject.toml no longer selects the ruff `S` security baseline -- restore "
        '[tool.ruff.lint] select = ["S"] (see the platform ADR 0085)'
    )
    assert set(lint.get("ignore", [])) <= {"S101", "S105", "S106"}, (
        "the `S` baseline excuses more than the sanctioned name-heuristic rules "
        "(S101/S105/S106); widening the ignores weakens the baseline"
    )
    for pattern, codes in lint.get("per-file-ignores", {}).items():
        assert "tests" in pattern.replace("\\", "/").split("/"), (
            f"per-file-ignores {pattern!r}: only test trees may excuse baseline rules"
        )
        assert set(codes) <= {"S311", "S603", "S607"}, (
            f"per-file-ignores {pattern!r} excuses more than the sanctioned test "
            "rules (S311/S603/S607)"
        )
    for key in ("exclude", "extend-exclude"):
        assert set(ruff.get(key, [])) <= {".venv", "**/migrations/versions"}, (
            f"[tool.ruff] {key} must not carve app code out of the security baseline "
            "(only .venv and generated Alembic revisions are sanctioned)"
        )
    ci = (project_root / ".github" / "workflows" / "ci.yml").read_text(encoding="utf-8")
    assert "uv run ruff check ." in ci, (
        ".github/workflows/ci.yml no longer runs the ruff `S` baseline as a "
        "blocking gate step (see the platform ADR 0085)"
    )


def test_every_module_is_mounted() -> None:
    # App modules are mounted explicitly in app/main.py. A scaffolded module that
    # never gets added to the `modules` list ships zero routes — every request
    # 404s and the module is absent from the OpenAPI contract — while the rest of
    # the gate stays green. Fail closed instead: every app/modules/<name> package
    # that declares a ModuleSpec must be reachable in the built app.
    manifests = sorted((_APP_ROOT / "modules").glob("*/module.py"))
    if not manifests:
        return  # nothing scaffolded yet (blank layout)
    from app.main import build

    paths = build().openapi()["paths"]
    for manifest in manifests:
        package = manifest.parent.name
        spec = importlib.import_module(f"app.modules.{package}.module").module
        prefix = f"/api/v1/{spec.name}"
        assert any(p == prefix or p.startswith(prefix + "/") for p in paths), (
            f"app/modules/{package} declares module {spec.name!r} but no {prefix} route is "
            "mounted — import it in app/main.py and add it to the `modules` list."
        )


def test_migrations_match_models(tmp_path: pathlib.Path) -> None:
    # The drift half of the migration control: upgrade a scratch database to head, then
    # assert autogenerate finds nothing left over. A model changed without
    # `terp migrate make <module>` fails here, in CI — not in production against a stale
    # schema (the boot guard only catches *pending* revisions, not a missing one).
    db_url = f"sqlite:///{tmp_path / 'drift-check.db'}"
    upgrade(db_url, _APP_ROOT, package="app")
    assert_migrations_match_models(db_url, _APP_ROOT, package="app")
