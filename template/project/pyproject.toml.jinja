[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_name }} — built on Terp"
requires-python = ">=3.13"
# terp-* distributions resolve from the package index (lockstep-versioned; see the
# platform CHANGELOG). Before a release is published, point uv at locally built wheels
# instead: `UV_FIND_LINKS=/path/to/terp-wheels uv sync` (the platform repo's
# template-acceptance CI job installs exactly this way).
dependencies = [
    "terp-core==0.1.0",
    "terp-cli==0.1.0",
    "terp-migrations==0.1.0",
    # Base profile: secure-by-default auth + identity + admin + audit.
    "terp-cap-auth==0.1.0",
    "terp-cap-identity==0.1.0",
    "terp-cap-users==0.1.0",
    "terp-cap-groups==0.1.0",
    "terp-cap-access==0.1.0",
    "terp-cap-audit==0.1.0",
{%- if use_files %}
    # File uploads: streamed storage + admin surface (auto-discovered, ADR 0056).
    "terp-cap-files==0.1.0",
{%- endif %}
{%- if use_sso %}
    # Single sign-on via OIDC (ADR 0058) — wired in app/auth.py, enabled by OIDC_* env.
    "terp-cap-oidc==0.1.0",
{%- endif %}
{%- if use_events %}
    # Domain events: typed catalog + in-process dispatch (ADR 0008).
    "terp-cap-eventbus==0.1.0",
{%- endif %}
]

[dependency-groups]
# uvicorn serves the local dev loop (`terp dev` / `uvicorn app.main:app`);
# the Docker images install their own pinned server.
dev = ["pytest>=8.0", "httpx>=0.27", "pytest-cov>=5.0", "terp-arch==0.1.0", "uvicorn>=0.30", "ruff>=0.6"]

[tool.hatch.build.targets.wheel]
packages = ["app", "control_plane"]

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["."]
addopts = "-q"

# The delegated generic AppSec baseline (ADR 0085): ruff's bandit-derived `S`
# rules cover the vulnerability classes the Terp Standard deliberately does NOT
# catalog (command injection, unsafe deserialization, weak hashes, ...) -- the
# terp.arch gate covers the Terp-specific architecture rules. Both run in CI
# (`uv run ruff check .` next to `uv run pytest`), and tests/test_architecture.py
# parses this stanza and fails on any weakening (a widened ignore, an exclude
# covering app code, a dropped CI step): weakening the baseline is a reviewed
# decision, never a silent one. Per-line opt-outs stay available as a `noqa`
# comment naming the S rule, with a reason.
[tool.ruff]
# Generated Alembic revisions are DDL, not app logic -- excluded exactly as the
# platform repo excludes its own.
extend-exclude = [".venv", "**/migrations/versions"]

[tool.ruff.lint]
# The name-only heuristics (S101 assert, S105/S106 "looks like a password") are
# excused platform-wide (ADR 0033); the high-signal rules stay on.
select = ["S"]
ignore = ["S101", "S105", "S106"]

[tool.ruff.lint.per-file-ignores]
# Tests legitimately spawn known subprocesses and use non-crypto randomness
# (root tests/ and any module-level tests/ tree alike).
"tests/**" = ["S603", "S607", "S311"]
"**/tests/**" = ["S603", "S607", "S311"]
