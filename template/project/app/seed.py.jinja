{% set singular = module_name[:-1] if module_name.endswith('s') else module_name -%}
{% set model = singular[0]|upper ~ singular[1:] if singular else '' -%}
"""Idempotent demo seed for {{ project_name }} — ``terp seed`` runs :func:`seed`.

Provisions a first administrator (so the app is loginnable){% if module_name %} and a couple of demo rows through
the real audited services{% endif %}. Idempotent, so a container may seed on every boot; dev / demo only
(``terp seed`` refuses to run when ``ENVIRONMENT=production`` — bootstrap a real admin with
``terp user create``). Edit this to seed whatever makes your app useful to work on.
"""

from __future__ import annotations

{% if module_name -%}
from sqlmodel import Session, select

from terp.core import BaseTable, Roles
{%- else -%}
from sqlmodel import Session

from terp.core import Roles
{%- endif %}

from terp.capabilities.users import UserProvision, UsersService
{% if module_name %}
from app.modules.{{ module_name }}.models import {{ model }}
from app.modules.{{ module_name }}.schemas import {{ model }}Create
from app.modules.{{ module_name }}.service import {{ model }}Service
{% endif %}
_ADMIN_EMAIL = "admin@example.test"
_DEMO_PASSWORD = "correct horse battery staple"  # noqa: S105 - dev seed, not a real secret

{% if module_name %}
def _has_any(session: Session, model: type[BaseTable]) -> bool:
    """True when *model* already has a row (so re-running seeds nothing twice)."""
    return session.exec(select(model).limit(1)).first() is not None

{% endif %}
def seed(session: Session) -> str:
    """Populate a fresh database with a usable admin{% if module_name %} and a little demo content{% endif %} (idempotent)."""
    users = UsersService()
    users.ensure_user(
        session,
        UserProvision(email=_ADMIN_EMAIL, password=_DEMO_PASSWORD, role=int(Roles.ADMIN)),
    )
{% if module_name %}
    if not _has_any(session, {{ model }}):
        service = {{ model }}Service()
        service.create(session, {{ model }}Create(name="First {{ singular }}"))
        service.create(session, {{ model }}Create(name="Second {{ singular }}"))

    return f"seeded admin ({_ADMIN_EMAIL}) + demo {{ module_name }}"
{% else %}
    return f"seeded admin ({_ADMIN_EMAIL})"
{% endif -%}
