"""Idempotent demo seed for {{ project_name }} — ``terp seed`` runs :func:`seed`.

Provisions a first administrator so the app is loginnable. Idempotent, so a
container may seed on every boot; dev / demo only (``terp seed`` refuses to run
when ``ENVIRONMENT=production`` — bootstrap a real admin with ``terp user
create``). When your first module lands, extend this to seed whatever makes the
app useful to work on (create rows through the module's real audited service,
never with raw SQL).
"""

from __future__ import annotations

from sqlmodel import Session

from terp.core import Roles

from terp.capabilities.users import UserProvision, UsersService

_ADMIN_EMAIL = "admin@example.test"
_DEMO_PASSWORD = "correct horse battery staple"  # noqa: S105 - dev seed, not a real secret


def seed(session: Session) -> str:
    """Populate a fresh database with a usable admin (idempotent)."""
    users = UsersService()
    users.ensure_user(
        session,
        UserProvision(email=_ADMIN_EMAIL, password=_DEMO_PASSWORD, role=int(Roles.ADMIN)),
    )
    return f"seeded admin ({_ADMIN_EMAIL})"
