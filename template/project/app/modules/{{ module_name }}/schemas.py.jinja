{% set model = singular[0]|upper ~ singular[1:] -%}
"""{{ model }} DTOs — cap every input string; the Read DTO is what the API returns."""

from __future__ import annotations

import datetime
import uuid

from sqlmodel import Field

from terp.core import BaseSchema, BaseUpdateSchema


class {{ model }}Create(BaseSchema):
    name: str = Field(max_length=200)


class {{ model }}Update(BaseUpdateSchema):
    name: str | None = Field(default=None, max_length=200)


class {{ model }}Read(BaseSchema):
    id: uuid.UUID
    name: str
    version: int
    created_at: datetime.datetime
    updated_at: datetime.datetime
