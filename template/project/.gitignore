# Local environment overrides — never commit (a real .env may hold SECRET_KEY).
# The tracked template is `.env.example`.
.env
.env.*
!.env.example
!.env.example.jinja

# Python
__pycache__/
*.py[cod]
.venv/
*.db
*.sqlite3

# Node / frontend build output
node_modules/
frontend/dist/

# Generated: the app's OpenAPI document and the typed client generated from it
# (`uv run terp openapi` + `npm --prefix frontend run generate`). Regenerated, never hand-edited.
/openapi.json
frontend/src/api/
