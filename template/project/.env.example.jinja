# Copy to `.env` and adjust; `docker compose` reads `.env` from this directory automatically.

# A strong secret (>= 32 chars) so issued JWTs stay valid across restarts. The compose file
# falls back to a dev default when this is unset, which is fine for a throwaway workbench but
# should be replaced with a real secret anywhere that matters.
SECRET_KEY=dev-secret-change-me-please-0123456789ab

# Host ports for the API and the frontend. Change these if 8000 / 5173 are already in use on
# your machine (the containers always talk to each other over the Compose network regardless).
API_PORT=8000
WEB_PORT=5173
{% if use_sso %}
# ---------------------------------------------------------------------------------
# Single sign-on (app/auth.py): the OIDC module mounts once these are set; leaving
# them unset boots the app with SSO off. The compose workbench forwards them into
# the api container.
# ---------------------------------------------------------------------------------
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5173/auth/sso/callback
{% endif %}
# ---------------------------------------------------------------------------------
# Production profile (docker-compose.prod.yml). In ENVIRONMENT=production the app
# REFUSES to boot on unsafe values (terp.core.config).
# ---------------------------------------------------------------------------------

# Required in production — compose fails fast when unset. SECRET_KEY >= 32 chars.
# SECRET_KEY=<openssl rand -hex 32>
# POSTGRES_PASSWORD=<strong database password>

# CORS is deny-by-default; list explicit origins only if the SPA is NOT served
# same-origin behind the bundled web entrypoint (never '*' — production refuses it).
# BACKEND_CORS_ORIGINS=["https://app.your-domain.example"]

# Host port for the production web entrypoint.
# WEB_PORT=8080
