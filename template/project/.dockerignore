# Build-context excludes for the workbench images (the build context is the repo root).
# Keeps the context small and avoids copying host-only or generated trees into the build.
**/node_modules
**/.venv
.git
**/__pycache__
**/*.pyc
**/*.pyo
**/dist
**/*.db
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.coverage
# Rendered env files — may hold secrets; images must never bake them in.
.env
.app.env
