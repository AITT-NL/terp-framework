{% if layout in ['hub', 'process', 'portal'] -%}
// The {{ layout }} landing: a HubPage of cards. These are PLACEHOLDERS — each card
// currently points at "/" because no module exists yet. When the first module lands
// (`uv run terp new module <name>` or the agent), point the cards at its route (and
// add a card per area as the app grows; a card can carry a live `stat`).
import { HubCard, HubPage } from "@terp/react-core";
import { Link } from "@tanstack/react-router";

export function Home() {
  return (
    <HubPage title="{% if layout == 'process' %}Werkvoorraad{% elif layout == 'portal' %}Mijn overzicht{% else %}{{ project_name }}{% endif %}">
{% if layout == 'process' -%}
      <HubCard
        to="/"
        title="Nieuw"
        description="Hier komt de lijst met nieuwe aanvragen zodra het eerste onderdeel is gebouwd."
        stat="Te beoordelen"
        renderLink={({ to, children }) => <Link to={to}>{children}</Link>}
      />
      <HubCard
        to="/"
        title="In behandeling"
        description="Hier ga je verder met aanvragen waaraan al wordt gewerkt."
        stat="Actief"
        renderLink={({ to, children }) => <Link to={to}>{children}</Link>}
      />
      <HubCard
        to="/"
        title="Afgerond"
        description="Hier vind je afgeronde aanvragen en hun geschiedenis."
        stat="Archief"
        renderLink={({ to, children }) => <Link to={to}>{children}</Link>}
      />
{%- elif layout == 'portal' -%}
      <HubCard
        to="/"
        title="Mijn zaken"
        description="Hier komen de gegevens die bij jouw account horen zodra het eerste onderdeel is gebouwd."
        stat="Persoonlijk"
        renderLink={({ to, children }) => <Link to={to}>{children}</Link>}
      />
      <HubCard
        to="/"
        title="Openstaande acties"
        description="Hier ga je verder met wat nog aandacht of informatie nodig heeft."
        stat="Actie nodig"
        renderLink={({ to, children }) => <Link to={to}>{children}</Link>}
      />
{%- else -%}
      <HubCard
        to="/"
        title="Eerste onderdeel"
        description="Hier komt je eerste onderdeel. Bouw het via de chat of met `terp new module`."
        renderLink={({ to, children }) => <Link to={to}>{children}</Link>}
      />
{%- endif %}
    </HubPage>
  );
}
{%- else -%}
// The blank-shell landing — replace it with your first real screen. Add modules with
// `uv run terp new module <name>` (or ask the agent); each drops in a routed, nav-linked slot.
import { Page } from "@terp/react-core";

export function Home() {
  return (
    <Page title="{{ project_name }}">
      <p>
        Your app is running: sign-in, admin and audit are already wired. Add your first
        module with <code>uv run terp new module &lt;name&gt;</code> — it appears in the
        navigation automatically.
      </p>
    </Page>
  );
}
{%- endif %}
