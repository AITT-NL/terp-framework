{
  "name": "@terpjs-example/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Terp example app — React frontend dogfooding @terpjs/react-core + @terpjs/contract against the example backend.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "generate": "openapi-typescript ../openapi.json --output ./src/api/schema.d.ts",
    "lint": "terp-boundaries-lint",
    "typecheck": "tsc --noEmit --incremental --tsBuildInfoFile node_modules/.cache/typecheck.tsbuildinfo",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.16",
    "@terpjs/contract": "*",
    "@terpjs/react-core": "*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@terpjs/conformance": "*",
    "@terpjs/eslint-boundaries": "*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.18.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.0"
  }
}
